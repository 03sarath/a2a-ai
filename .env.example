# Gemini API Key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Neon PostgreSQL (for host agent session persistence)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require

# URLs of deployed Cloud Run services (fill after deployment)
MARKET_SCANNER_URL=https://market-scanner-xxxx-uc.a.run.app
SENTIMENT_ANALYZER_URL=https://sentiment-analyzer-xxxx-uc.a.run.app
PRICING_INTEL_URL=https://pricing-intel-xxxx-uc.a.run.app
REPORT_GENERATOR_URL=https://report-generator-xxxx-uc.a.run.app
